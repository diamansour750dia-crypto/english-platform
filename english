<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UCA English Platform | Mansour & Kevin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .uca-blue { background-color: #004a99; }
        .uca-red { background-color: #e60028; }
        .sidebar-scroll::-webkit-scrollbar { width: 4px; }
        .sidebar-scroll::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }
        .hidden { display: none !important; }
    </style>
</head>
<body class="bg-slate-50 flex h-screen overflow-hidden">

    <div id="auth-screen" class="fixed inset-0 z-[100] flex items-center justify-center bg-slate-900/95 backdrop-blur-md">
        <div class="bg-white w-full max-w-md p-10 rounded-[2.5rem] shadow-2xl text-center border-t-8 border-[#004a99]">
            <img src="https://upload.wikimedia.org/wikipedia/fr/thumb/3/3a/Logo_Universit%C3%A9_Clermont_Auvergne_2021.svg/1200px-Logo_Universit%C3%A9_Clermont_Auvergne_2021.svg.png" 
                 class="h-16 mx-auto mb-8" alt="UCA Logo">
            
            <h2 class="text-3xl font-extrabold text-slate-900 mb-2">Student Login</h2>
            <p class="text-slate-500 mb-8 font-medium italic">English Learning Project 2026</p>
            
            <div class="space-y-4">
                <input type="text" id="name-input" placeholder="Full Name" 
                       class="w-full p-4 bg-slate-100 rounded-2xl border-none focus:ring-2 focus:ring-blue-600 outline-none font-semibold text-slate-700">
                <input type="email" placeholder="Email (@etu.uca.fr)" 
                       class="w-full p-4 bg-slate-100 rounded-2xl border-none focus:ring-2 focus:ring-blue-600 outline-none font-semibold text-slate-700">
                <button type="button" onclick="login()" class="w-full py-5 uca-blue text-white font-bold rounded-2xl shadow-xl hover:opacity-90 transition-all transform hover:scale-105">
                    Start Learning
                </button>
            </div>
            <p class="mt-8 text-[10px] text-slate-400 uppercase tracking-widest font-bold">Mansour Dia & Kevin Gové</p>
        </div>
    </div>

    <aside id="sidebar" class="w-80 bg-slate-900 text-white flex flex-col shadow-2xl hidden">
        <div class="p-6 bg-white border-b-4 border-[#004a99]">
            <img src="https://upload.wikimedia.org/wikipedia/fr/thumb/3/3a/Logo_Universit%C3%A9_Clermont_Auvergne_2021.svg/1200px-Logo_Universit%C3%A9_Clermont_Auvergne_2021.svg.png" 
                 class="h-12 mx-auto">
        </div>
        
        <div class="p-5 bg-slate-800/50">
            <div class="flex justify-between items-center mb-2 text-[10px] font-black uppercase text-slate-400 tracking-widest">
                <span>Course Progress</span>
                <span id="progress-percent">0%</span>
            </div>
            <div class="w-full bg-slate-700 rounded-full h-2">
                <div id="progress-bar" class="bg-emerald-500 h-2 rounded-full transition-all duration-700" style="width: 0%"></div>
            </div>
        </div>

        <div class="sidebar-scroll flex-grow overflow-y-auto p-4 space-y-8">
            <div>
                <h3 class="text-blue-400 text-[10px] font-black uppercase tracking-tighter mb-4 px-2">Grammar (50 Lessons)</h3>
                <div id="grammar-list" class="space-y-1"></div>
            </div>
            <div>
                <h3 class="text-red-400 text-[10px] font-black uppercase tracking-tighter mb-4 px-2">Vocabulary (50 Lessons)</h3>
                <div id="vocab-list" class="space-y-1"></div>
            </div>
        </div>
        
        <div class="p-4 bg-black text-center border-t border-slate-800">
            <p class="text-[10px] text-slate-500 font-bold uppercase">UCA Project - Mansour & Kevin</p>
        </div>
    </aside>

    <main id="content" class="flex-grow overflow-y-auto hidden bg-white">
        <header class="bg-white/80 backdrop-blur-md border-b border-slate-100 p-6 sticky top-0 z-10 flex justify-between items-center">
            <h1 class="text-xs font-black text-slate-400 uppercase tracking-widest italic">English for Students</h1>
            <div class="flex items-center gap-3">
                <span id="user-display" class="font-bold text-slate-700 text-sm">Student</span>
                <div class="h-10 w-10 rounded-full uca-blue flex items-center justify-center text-white font-bold text-xs shadow-inner">UCA</div>
            </div>
        </header>

        <div class="p-10 max-w-4xl mx-auto">
            <div id="welcome-message" class="text-center py-20">
                <div class="uca-blue w-20 h-20 rounded-3xl rotate-6 mx-auto mb-8 flex items-center justify-center shadow-2xl">
                    <span class="text-white text-3xl font-extrabold italic">En</span>
                </div>
                <h2 class="text-4xl font-black text-slate-900 mb-4 leading-tight">Ready to improve?</h2>
                <p class="text-slate-500 text-lg max-w-md mx-auto">Select a specialized module from the sidebar to begin your training session.</p>
            </div>

            <div id="lesson-view" class="hidden animate-in fade-in duration-500 space-y-10">
                <div class="bg-white rounded-[2.5rem] p-10 shadow-xl border border-slate-50">
                    <span id="category-tag" class="text-[10px] font-black text-white px-3 py-1 rounded-full uppercase mb-6 inline-block">Category</span>
                    <h2 id="lesson-title" class="text-4xl font-black text-slate-900 mb-6 border-b pb-6 border-slate-50">Lesson Title</h2>
                    <div id="lesson-text" class="text-slate-600 text-xl leading-relaxed space-y-4"></div>
                </div>

                <div class="bg-slate-900 rounded-[2.5rem] p-10 text-white shadow-2xl">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="w-3 h-3 rounded-full uca-red animate-pulse"></div>
                        <h3 class="text-xl font-bold uppercase tracking-widest">Self-Assessment Quiz</h3>
                    </div>
                    <p id="quiz-question" class="text-xl mb-10 text-slate-300"></p>
                    <div id="quiz-options" class="grid grid-cols-1 md:grid-cols-2 gap-5"></div>
                    <div id="quiz-result" class="mt-8 hidden p-6 rounded-2xl text-center font-
